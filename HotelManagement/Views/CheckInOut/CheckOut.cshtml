@model HotelManagement.Models.Entities.Booking

@{
    ViewData["Title"] = "Xác nhận check-out";
}

<h1>Xác nhận check-out</h1>

<div>
    <h4>Booking #@Model.Id</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Khách hàng</dt>
        <dd class="col-sm-10">@Model.Customer?.FullName</dd>

        <dt class="col-sm-2">Ngày nhận</dt>
        <dd class="col-sm-10">@Model.CheckInDate.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-2">Ngày trả</dt>
        <dd class="col-sm-10">@Model.CheckOutDate.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-2">Phòng</dt>
        <dd class="col-sm-10">
            @string.Join(", ", Model.BookingDetails.Select(bd => bd.Room?.RoomNumber))
        </dd>
    </dl>

    <form asp-action="CheckOut" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xác nhận check-out" class="btn btn-danger" />
        <a asp-action="CheckOutList" class="btn btn-secondary">Hủy</a>
    </form>
</div>