@model IEnumerable<HotelManagement.Models.ViewModels.OccupancyReportViewModel>

@{
    ViewData["Title"] = "Báo cáo công suất phòng";
    int year = ViewBag.Year;
    int month = ViewBag.Month;
}

<h1>Báo cáo công suất phòng tháng @month/@year</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" class="form-inline">
            <div class="form-group mr-2">
                <label>Năm: </label>
                <select name="year" class="form-control">
                    @for (int y = 2023; y <= DateTime.Now.Year; y++)
                    {
                        <option value="@y" selected="@(y == year)">@y</option>
                    }
                </select>
            </div>
            <div class="form-group mr-2">
                <label>Tháng: </label>
                <select name="month" class="form-control">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == month)">@m</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Xem</button>
        </form>
    </div>
    <div class="col-md-6 text-right">
        <h4>Tổng số phòng: @ViewBag.TotalRooms</h4>
        <p>Số ngày trong tháng: @ViewBag.DaysInMonth</p>
    </div>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Số phòng</th>
            <th>Loại phòng</th>
            <th>Số ngày có khách</th>
            <th>Tỷ lệ lấp đầy</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RoomNumber</td>
                <td>@item.RoomType</td>
                <td>@item.TotalDaysOccupied</td>
                <td>
                    @item.OccupancyRate.ToString("0.00")%
                    <div class="progress">
                        <div class="progress-bar" role="progressbar" style="width: @item.OccupancyRate%"></div>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Revenue" asp-route-year="@year" asp-route-month="@month" class="btn btn-info">Xem báo cáo doanh thu</a>
</div>