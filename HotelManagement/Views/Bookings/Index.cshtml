@using HotelManagement.Models.Entities

@model IEnumerable<Booking>

@{
    ViewData["Title"] = "Danh sách đặt phòng";
}

<h1>Danh sách đặt phòng</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Đặt phòng mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Khách hàng</th>
            <th>Ngày nhận</th>
            <th>Ngày trả</th>
            <th>Số người lớn</th>
            <th>Số trẻ em</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Customer?.FullName</td>
                <td>@item.CheckInDate.ToString("dd/MM/yyyy")</td>
                <td>@item.CheckOutDate.ToString("dd/MM/yyyy")</td>
                <td>@item.NumberOfAdults</td>
                <td>@item.NumberOfChildren</td>
                <td>@item.TotalPrice.ToString("N0") VNĐ</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>>