@model HotelManagement.Models.Entities.Service

@{
    ViewData["Title"] = "Xóa dịch vụ";
}

<h1>Xóa dịch vụ</h1>
<div class="alert alert-danger">
    Bạn có chắc muốn xóa dịch vụ <strong>@Model.Name</strong>? Hành động này không thể hoàn tác.
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Tên</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Đơn vị</dt>
        <dd class="col-sm-10">@Model.Unit</dd>
        <dt class="col-sm-2">Đơn giá</dt>
        <dd class="col-sm-10">@Model.Price.ToString("N0") VNĐ</dd>
        <dt class="col-sm-2">Mô tả</dt>
        <dd class="col-sm-10">@Model.Description</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>