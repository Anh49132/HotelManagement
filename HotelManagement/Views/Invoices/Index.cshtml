@model IEnumerable<HotelManagement.Models.Entities.Invoice>

@{
    ViewData["Title"] = "Quản lý hóa đơn";
}

<h1>Danh sách hóa đơn</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Mã HD</th>
            <th>Khách hàng</th>
            <th>Ngày lập</th>
            <th>Tổng tiền</th>
            <th>Đã thanh toán</th>
            <th>Còn lại</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            decimal remaining = item.TotalAmount - item.PaidAmount;
            <tr>
                <td>@item.Id</td>
                <td>@item.Booking?.Customer?.FullName</td>
                <td>@item.InvoiceDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.TotalAmount.ToString("N0") VNĐ</td>
                <td>@item.PaidAmount.ToString("N0") VNĐ</td>
                <td>@remaining.ToString("N0") VNĐ</td>
                <td>
                    @if (item.Status == "Paid")
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else if (item.Status == "Partial")
                    {
                        <span class="badge bg-warning">Thanh toán một phần</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Chưa thanh toán</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    @if (item.Status != "Paid")
                    {
                        <a asp-action="Pay" asp-route-id="@item.Id" class="btn btn-sm btn-success">Thanh toán</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>